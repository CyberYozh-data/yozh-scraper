# Service
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO

# Upstream scraper (inside docker network use service name)
SCRAPER_URL=http://web-scraper:8000
SCRAPER_JOB_POLL_INTERVAL_MS=250
SCRAPER_JOB_TIMEOUT_MS=120000

# Workers = number of parallel crawl jobs (mirrors scraper's WORKERS knob)
WORKERS=2
QUEUE_MAXSIZE=200
JOB_TIMEOUT_MS=3600000

# Retry
MAX_RETRIES=3
RETRY_HTTP_CODES=[408,429,500,502,503,504]
RETRY_BACKOFF_BASE=2.0
RETRY_BACKOFF_MAX=30.0

# Session pool (Crawlee defaults)
SESSION_MAX_ERROR_SCORE=3.0
SESSION_MAX_USAGE=50
SESSION_BLOCKED_CODES=[401,403,429]

# CORS (crawler is reached directly from browser for SSE)
CORS_ALLOW_ORIGINS=["*"]
